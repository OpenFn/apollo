OPENAI_API_KEY=sk-YOUR-API-KEY-HERE
ANTHROPIC_API_KEY=sk-YOUR-API-KEY-HERE
PINECONE_KEY=YOUR-API-KEY-HERE
POSTGRES_URL=postgresql://localhost:5432/apollo_dev
SENTRY_DSN=YOUR-API-KEY-HERE
GITHUB_TOKEN=KEY

# Instance auth (optional): set INSTANCE_AUTH=true to require a bearer token on
# /services/*. When enabled, Apollo looks tokens up in the lightning_clients
# table via POSTGRES_URL (see services/_instance_auth/). Leave unset/false to
# keep the server open as before. Requires Bun >= 1.2 (Bun.SQL).
INSTANCE_AUTH=false

# Optional: pin the shared secret for internal service-to-service calls (the
# apollo() helper). When INSTANCE_AUTH=true, Apollo auto-generates one at startup
# and spawned services inherit it, so internal auth works with no config. The gate
# never trusts callers by network address. Set this only to pin a stable value
# (e.g. if you run Python services outside Apollo's process).
APOLLO_INTERNAL_SECRET=

# Langfuse observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# HF_ACCESS_TOKEN=hf_YOUR-API-KEY-HERE # llama2 base
# ZILLIZ_URI =  https://in01-XXXXXXXXXXXXX.aws-us-west-2.vectordb.zillizcloud.com:XXXXX
# ZILLIZ_TOKEN =db_admin:password (or ApiKey)

